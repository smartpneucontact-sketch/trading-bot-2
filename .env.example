# Alpaca paper trading credentials
# Separate key/secret per model allows running multiple bots in parallel on separate paper accounts
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Where to store DuckDB, models, cache.
# Local: ./data
# Railway (with volume mounted): /app/data
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO

# Flask dashboard
DASHBOARD_PORT=8000

# FinBERT model (override if using a different HF variant)
FINBERT_MODEL=ProsusAI/finbert

# Anthropic API key (for Claude news enrichment — only needed when running
# `bot8 features news-claude --submit`). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Rebalance schedule (America/New_York)
REBALANCE_TIME=09:35
PREMARKET_FETCH_TIME=07:00
PREMARKET_SCORE_TIME=07:30

# Portfolio parameters
TARGET_GROSS_EXPOSURE=1.0   # sum of |weights|
MAX_NET_EXPOSURE=0.10       # dollar-neutral band ±10%
LONG_DECILE=0.1             # top 10% by rank go long
SHORT_DECILE=0.1            # bottom 10% by rank go short
MAX_POSITION_WEIGHT=0.02    # 2% gross cap per name

# Risk controls
MIN_REGIME_EXPOSURE=0.4     # scale down in hostile regimes
MAX_DRAWDOWN_STOP=0.15      # kill switch if drawdown exceeds this
